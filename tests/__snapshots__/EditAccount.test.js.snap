// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renders EDIT mode correctly 1`] = `"<div><!----><!----> <div class="form"><div class="form-heading">Edit Account</div> <div class="toolbar toolbar-right"><button class="toolbar-icon" title="Delete account"><!----><!----></button><!----></div> <div class="form-row svelte-fi4apn"><div class="widget svelte-fi4apn"><label for="name">Name</label> <input id="name" class="description-input svelte-fi4apn"></div> <div class="widget svelte-fi4apn"><label for="startingBalance">Starting balance</label> <input id="startingBalance" class="money-input svelte-fi4apn"></div></div> <div class="form-row svelte-fi4apn"><div class="widget svelte-124sfg"><label for="itemSelect" class="svelte-124sfg">Type</label><!----> <select name="itemSelect" class="svelte-124sfg flat"><!----><!----><option value="[object Object]">Asset</option><!----><option value="[object Object]">Liability</option><!----><option value="[object Object]">Revenue</option><!----><option value="[object Object]">Expense</option><!----><option value="[object Object]">Equity</option><!----></select></div><!----></div> <div class="form-button-row svelte-fi4apn"><div class="msg-panel svelte-fi4apn"><!----> <!----></div> <div class="widget buttons svelte-fi4apn"><button class="og-button">Close</button> <button class="og-button">Update</button></div></div> <!----> <hr> <div class="info-title svelte-bv9d08">Interest</div> <div class="toolbar"><button class="toolbar-icon" title="Add an interest entry"><!----><!----></button></div><!----> <!----><!----><!----></div> <hr></div>"`;

exports[`renders NEW mode correctly 1`] = `"<div><!----><!----> <div class="form"><div class="form-heading">New Account</div> <div class="toolbar toolbar-right"><button class="toolbar-icon" title="Delete account"><!----><!----></button><!----></div> <div class="form-row svelte-fi4apn"><div class="widget svelte-fi4apn"><label for="name">Name</label> <input id="name" class="description-input svelte-fi4apn"></div> <div class="widget svelte-fi4apn"><label for="startingBalance">Starting balance</label> <input id="startingBalance" class="money-input svelte-fi4apn"></div></div> <div class="form-row svelte-fi4apn"><div class="widget svelte-124sfg"><label for="itemSelect" class="svelte-124sfg">Type</label><!----> <select name="itemSelect" class="svelte-124sfg flat"><!----><!----><option value="[object Object]">Asset</option><!----><option value="[object Object]">Liability</option><!----><option value="[object Object]">Revenue</option><!----><option value="[object Object]">Expense</option><!----><option value="[object Object]">Equity</option><!----></select></div><!----></div> <div class="form-button-row svelte-fi4apn"><div class="msg-panel svelte-fi4apn"><!----> <!----></div> <div class="widget buttons svelte-fi4apn"><button class="og-button">Close</button> <button class="og-button">Add</button></div></div> <!----> <!----></div> <hr></div>"`;
